# ── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/batteryloop

# ── Google OAuth ────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── JWT ─────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRE=7d

# ── Admin ───────────────────────────────────────
# Comma-separated emails that get admin role on first login
ADMIN_EMAILS=admin@batteryloop.com

# ── Frontend ────────────────────────────────────
FRONTEND_URL=http://localhost:3000
